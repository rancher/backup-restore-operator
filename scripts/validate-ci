#!/bin/bash
set -e

cd $(dirname $0)/..

go generate

# Ensure go.work.sum is in sync with all workspace modules.
# If a go.mod was updated without running `go work sync`, this will catch it.
if [ -f go.work ]; then
    go work sync
fi

source ./scripts/version

if [ -n "$DIRTY" ]; then
    echo Git is dirty
    git status
    git diff
    exit 1
fi
